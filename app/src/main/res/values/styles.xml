<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.BoeroCamera" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:windowBackground">@color/camera_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/camera_bg</item>
        <item name="colorControlHighlight">#33FFFFFF</item>
    </style>


    <style name="Theme.BoeroCamera.Light" parent="Theme.MaterialComponents.Light">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>


    <style name="Theme.BoeroCamera.ActionBar" parent="Theme.BoeroCamera">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
        <item name="actionBarStyle">@style/BoeroActionBar</item>
    </style>

    <style name="BoeroActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/surface</item>
        <item name="titleTextStyle">@style/ActionBarTitle</item>
    </style>

    <style name="ActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="SectionHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textColor">@color/accent_blue</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.15</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SettingsCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginHorizontal">12dp</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:background">@drawable/bg_settings_card</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="ModeButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:background">@drawable/bg_mode_button</item>
        <item name="android:textStyle">bold</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="ZoomButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">12sp</item>
        <item name="android:background">@drawable/bg_zoom_button</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="WbButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">12sp</item>
        <item name="android:background">@drawable/bg_wb_button</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="AspectButton">
        <item name="android:layout_height">40dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:background">@drawable/bg_aspect_button</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

</resources>
